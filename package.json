{
  "name": "subly",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:backend": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "test:restart-smoke": "cargo test --manifest-path src-tauri/Cargo.toml restart_smoke_ --lib",
    "test:known-risks": "cargo test --manifest-path src-tauri/Cargo.toml --lib -- --ignored",
    "cargo:outdated": "cargo outdated --manifest-path src-tauri/Cargo.toml --workspace --depth 1 -x tauri-plugin-single-instance --verbose",
    "bump:version": "node scripts/bump-app-version.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.14.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-deep-link": "~2.4.9",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "echarts": "^6.0.0",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.4.2",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "~5.9.3",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@9.15.9"
}
