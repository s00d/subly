<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.subly" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Fallback background that matches the splash for legacy code paths (e.g. window animations). -->
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <!-- Splash theme applied to the launcher Activity. Uses Android 12+ SplashScreen API
         and falls back to windowBackground on older devices via androidx.core.splashscreen. -->
    <style name="Theme.subly.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.subly</item>
    </style>
</resources>
